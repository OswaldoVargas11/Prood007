# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Prisma
apps/api/prisma/migrations/dev.db*

# Env / secrets
.env
.env.*
!.env.example
# Backups efímeros que pueden contener secretos (p. ej. .env.bak.<ts>) — nunca al repo.
*.bak
*.bak.*

# Logs
*.log
logs/
npm-debug.log*

# Claude Code local settings
.claude/settings.local.json

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Coverage / test
coverage/
coverage-e2e/
.nyc_output/

# Diff efímero del harness de conformidad fiscal (se sube como artifact en CI,
# nunca se committea). Los golden files SÍ se versionan; el .diff/ no.
packages/compliance/test/fiscal-conformance/.diff/

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/

# Local storage en runtime (dev disk StorageProvider) — solo directorios de datos,
# NO el código fuente apps/api/src/storage/.
/storage/
/apps/api/storage/
uploads/

# Docker volumes (if mounted locally)
.docker-data/

# Playwright e2e seed (generado por global-setup)
apps/web/e2e/.auth/

# QA exploratorio (capturas de trabajo)
qa-screenshots/

# Scripts de prueba locales (pueden contener credenciales de entorno)
scripts/test-*.mjs

# Stripe setup-as-code: salida generada con los Price IDs (pegar en STRIPE_PRICE_MAP)
scripts/stripe-prices.*.json

# Artefactos locales del pentest vivo (LAW-31): tokens/ids de entorno de prueba, NO versionar
.pentest-actors.json
.pentest-fixtures.json
