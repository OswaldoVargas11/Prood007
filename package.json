{
  "name": "legalflow",
  "version": "0.1.0",
  "private": true,
  "description": "LegalFlow — SaaS de gestión legal multi-jurisdicción (ES/DO). Núcleo agnóstico + adaptadores de cumplimiento.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter @legalflow/api start:dev",
    "web:dev": "pnpm --filter @legalflow/web dev",
    "db:migrate": "pnpm --filter @legalflow/api prisma:migrate",
    "db:generate": "pnpm --filter @legalflow/api prisma:generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "auditConfig": {
      "//": "Allowlist REVISADA de advisories de PRODUCCIÓN aceptados temporalmente (ver DECISIONS D-017). El gate de seguridad bloquea cualquier vuln alta/crítica de prod que NO esté aquí. Cada entrada requiere remediación rastreada (migración Next 15; override de multer/lodash).",
      "ignoreGhsas": [
        "GHSA-h25m-26qc-wcjf",
        "GHSA-q4gf-8mx6-v5v3",
        "GHSA-8h8q-6873-q5fj",
        "GHSA-c4j6-fc7j-m34r",
        "GHSA-36qx-fr4f-26g5",
        "GHSA-xf7r-hgr6-v32p",
        "GHSA-v52c-386h-88mc",
        "GHSA-5528-5vmv-3xc2",
        "GHSA-r5fr-rjxr-66jc"
      ]
    }
  }
}
