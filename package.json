{
  "name": "legalflow",
  "version": "0.1.0",
  "private": true,
  "description": "LegalFlow — SaaS de gestión legal multi-jurisdicción (ES/DO). Núcleo agnóstico + adaptadores de cumplimiento.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter @legalflow/api start:dev",
    "web:dev": "pnpm --filter @legalflow/web dev",
    "db:migrate": "pnpm --filter @legalflow/api prisma:migrate",
    "db:generate": "pnpm --filter @legalflow/api prisma:generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
