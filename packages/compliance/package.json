{
  "name": "@legalflow/compliance",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:fiscal-conformance": "jest -c jest.conformance.cjs --runInBand"
  },
  "dependencies": {
    "@legalflow/domain": "workspace:*"
  },
  "devDependencies": {
    "@legalflow/config": "workspace:*",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
