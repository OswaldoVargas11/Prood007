{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "forceExit": true,
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/auth/**/*.ts",
    "!src/**/*.module.ts",
    "!src/**/*.dto.ts",
    "!src/**/index.ts"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageThreshold": {
    "global": {
      "statements": 88,
      "lines": 88,
      "functions": 85,
      "branches": 65
    }
  }
}
