// LegalFlow — esquema de dominio (Prisma + PostgreSQL).
//
// MULTI-TENANCY: aislamiento row-level por `tenantId` en toda tabla de negocio, con índices
// compuestos (tenantId, ...). Postgres RLS ACTIVA como defensa en profundidad (ver DECISIONS
// D-004 y D-013): políticas por current_setting('app.tenant_id'); el runtime conecta como rol de
// mínimo privilegio y fija el GUC por request.
//
// AGNOSTICISMO: este esquema NO codifica ninguna ley concreta. Los campos fiscales específicos
// de cada país viajan en `Invoice.complianceRecord` (JSON opaco) generado por el ComplianceProvider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // url = rol de aplicación de mínimo privilegio (sin superusuario) → RLS SÍ se aplica en runtime.
  url       = env("DATABASE_URL")
  // directUrl = rol propietario/privilegiado, usado SOLO por Prisma Migrate (DDL, roles, RLS).
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (espejo de @legalflow/domain)
// ─────────────────────────────────────────────────────────────────────────────

enum Jurisdiction {
  es
  do
}

enum Currency {
  EUR
  USD
  DOP
}

enum MatterStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum DocumentReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum LedgerEntryType {
  PROVISION
  DISBURSEMENT
  TIME_FEE
  FEE
  INVOICE
  PAYMENT
  ADJUSTMENT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIAL
  OVERDUE
  PAID
  CANCELLED
}

// Tipo de documento de factura. NORMAL = caso general; RECTIFICATIVA corrige una factura ya emitida
// (devolución de un anticipo facturado, D-027 (c)). Bajo Verifactu/e-CF la rectificativa es un registro
// NUEVO encadenado que referencia la rectificada (las facturas no se modifican/borran).
enum InvoiceDocumentType {
  NORMAL
  RECTIFICATIVA
}

// Método de la rectificativa (D-027 (c)): SUSTITUCION (la errónea en negativo + la rectificativa; método
// de R3c para devolución total) | DIFERENCIAS (solo el delta; reservado para refund parcial, no en R3c).
enum RectificationMode {
  SUSTITUCION
  DIFERENCIAS
}

// Estado de aprobación de un apunte del ledger (flujo de aprobación de costes).
// Por defecto APPROVED (los apuntes normales no requieren aprobación); un coste propuesto por un
// letrado nace PROPOSED y el admin lo aprueba o rechaza.
enum ApprovalStatus {
  PROPOSED
  APPROVED
  REJECTED
}

// Estado de un cobro (Payment) sobre una factura.
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// Canal de entrega de un recordatorio de cobro (dunning). Hoy solo IN_APP; EMAIL/SMS reservados para
// Fase 2 (punto de integración, sin canal construido aún). Ver enums de @legalflow/domain.
enum DunningChannel {
  IN_APP
  EMAIL
  SMS
}

// Severidad/escalado del recordatorio: recordatorio → aviso → aviso final, según crece el retraso.
enum DunningSeverity {
  REMINDER
  WARNING
  FINAL
}

// Estado de un recordatorio concreto: planificado, entregado, omitido (factura cobrada antes), fallido.
enum DunningReminderStatus {
  SCHEDULED
  SENT
  SKIPPED
  FAILED
}

// Movimiento del saldo de provisión de fondos (retainer) de un expediente. Signo: DEPOSIT +,
// APPLICATION −, REFUND −, ADJUSTMENT ± (el importe lleva su signo). Ver enums de @legalflow/domain.
enum RetainerMovementType {
  DEPOSIT
  APPLICATION
  REFUND
  ADJUSTMENT
}

// Naturaleza fiscal de un DEPOSIT de provisión (ANTICIPO devenga IVA/ITBIS y exige factura — habilitado
// en R2b; SUPLIDO fuera de base; GENERICO sin devengo). Ver D-026 y enums de @legalflow/domain.
enum ProvisionKind {
  ANTICIPO
  SUPLIDO
  GENERICO
}

// Facturación programada (recurrente / planes de pago). Un único motor cubre ambos casos.
// - RECURRING: servicio continuado (iguala) → 1 factura por periodo (devengo en cada periodo).
// - INSTALLMENTS: un importe fraccionado; el tratamiento fiscal depende de `BillingFiscalMode`.
enum BillingScheduleType {
  RECURRING
  INSTALLMENTS
}

// Tratamiento fiscal del fraccionamiento (solo INSTALLMENTS; ver D-026/D-027):
// - SERVICE_RENDERED: el servicio ya se prestó/contrató → 1 factura (IVA completo al emitir) + cuotas
//   como COBROS parciales (Payment); las cuotas NO son facturas nuevas.
// - ADVANCE: se cobra por adelantado → cada cuota es un ANTICIPO → factura de anticipo por cuota
//   (devengo al cobro, flujo R2b); la factura final deduce los anticipos (R3b).
enum BillingFiscalMode {
  SERVICE_RENDERED
  ADVANCE
}

// Cadencia de un plan recurrente (cada `intervalCount` × `intervalUnit`).
enum BillingInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// Estado del plan de facturación.
enum BillingScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// Estado de una cuota/periodo concreto del plan. SCHEDULED → EMITTED (factura emitida) → PAID;
// SKIPPED (omitida) / FAILED (cobro o emisión fallida, a reintentar/avisar).
enum BillingInstallmentStatus {
  SCHEDULED
  EMITTED
  PAID
  SKIPPED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy & Auth / RBAC
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id                    String       @id @default(cuid())
  name                  String
  // Identificador fiscal del despacho emisor (NIF/CIF en ES, RNC en RD). Necesario para facturar.
  taxId                 String?
  jurisdiction          Jurisdiction
  currency              Currency
  locale                String       @default("es-ES")
  // Licencia / suscripción: plan y plazas contratadas (asientos) por rol de staff.
  plan                  String       @default("Profesional")
  // Máximo de usuarios ACTIVOS por rol (la licencia del despacho).
  maxAdmins             Int          @default(2)
  maxLawyers            Int          @default(5)
  // SaaS de plataforma (suscripción del despacho a Lawzora; distinto del cobro despacho→cliente).
  // Prueba de 15 días con todo desbloqueado; al expirar sin suscripción → muro (SubscriptionGuard).
  subscriptionStatus    String       @default("TRIALING") // TRIALING|ACTIVE|PAST_DUE|SUSPENDED|CANCELED
  // Modelo POR USUARIO: producto completo, se paga por plaza de staff. `seats` = plazas contratadas
  // (0 = en prueba, sin compra). Precio por plaza con descuento por volumen (ver subscription/plans.ts).
  seats                 Int          @default(0)
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  // Ciclo de facturación de la suscripción: MONTHLY | ANNUAL (anual = 2 meses gratis, ver plans.ts).
  billingCycle          String       @default("MONTHLY")
  // Cancelación programada: el admin canceló y la suscripción seguirá ACTIVE hasta `currentPeriodEnd`,
  // momento en que Stripe emite `customer.subscription.deleted` y pasa a CANCELED. true = baja agendada
  // (la UI muestra "se cancelará el …" y ofrece reanudar). Lo sincroniza el webhook de Stripe.
  cancelAtPeriodEnd     Boolean      @default(false)
  // Plan Fundador (primeros N despachos): el precio POR PLAZA queda bloqueado de por vida según los
  // tramos de volumen vigentes al darse de alta. `lockedSeatTiers` = snapshot [{upTo, pricePerSeatEur}].
  // El precio por plaza sigue dependiendo del nº de plazas (volumen); lo que se congela es la tarifa.
  isFounder             Boolean      @default(false)
  founderNumber         Int?
  lockedSeatTiers       Json?
  // Serie fiscal: prefijo de la numeración de facturas (p. ej. "FAC", "A").
  invoiceSeries         String       @default("FAC")
  // Canal de correo de los recordatorios de plazos: interruptor del DESPACHO. En false no se envía
  // ningún recordatorio por email a nadie del despacho (el aviso in-app se mantiene siempre).
  deadlineEmailRemindersEnabled Boolean @default(true)
  // Festivos locales del despacho: array JSON [{ date: "yyyy-mm-dd", name }] que afina el cómputo de
  // plazos procesales (se suman a los festivos nacionales de la jurisdicción).
  holidays              Json?
  // Certificado digital del despacho (para firmar/emitir). Metadatos; el fichero va al StorageProvider.
  certificateName       String?
  certificateKey        String?
  certificateUploadedAt DateTime?
  // Contraseña del certificado .p12, CIFRADA (AES-256-GCM con DATA_ENCRYPTION_KEY); nunca en claro.
  certificatePasswordEnc String?
  savedViews             SavedView[]
  emailSnippets          EmailSnippet[]
  // RGPD/Ley 172-13 — gobernanza de datos (D-022): región de residencia de datos del despacho
  // (p. ej. "EU" para ES; a definir para RD) y política de conservación configurable en meses. La
  // RETENCIÓN es metadato/política (la conservación legal prevalece sobre el borrado); no auto-purga.
  dataRegion            String?
  retentionMonths       Int?
  // Cuenta conectada de Stripe (Connect Standard) del despacho. El cobro online va a SU cuenta, no a la
  // plataforma (evita ser transmisor de fondos). Vacío = el despacho aún no ha conectado Stripe. Ver D-024.
  stripeAccountId       String?
  // Suscripción de PLATAFORMA: el despacho como cliente de Lawzora en el Stripe de la plataforma
  // (distinto de stripeAccountId, que es su cuenta Connect para cobrar a SUS clientes).
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  // Captación (CRM): token público del formulario de intake del despacho. Vacío hasta generarlo en Ajustes.
  intakeToken           String?      @unique
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  users               User[]
  roles               Role[]
  clients             Client[]
  matters             Matter[]
  documents           Document[]
  documentTemplates   DocumentTemplate[]
  kycProfiles         KycProfile[]
  tasks               Task[]
  timeEntries         TimeEntry[]
  ledgerEntries       LedgerEntry[]
  invoices            Invoice[]
  payments            Payment[]
  dunningRules        DunningRule[]
  dunningReminders    DunningReminder[]
  retainerAccounts    RetainerAccount[]
  retainerEntries     RetainerEntry[]
  billingSchedules    BillingSchedule[]
  billingInstallments BillingInstallment[]
  notifications       Notification[]
  messages            Message[]
  auditLogs           AuditLog[]
  signatureRequests   SignatureRequest[]
  leads               Lead[]
  oauthConnections    OAuthConnection[]
  matterEmails        MatterEmail[]
  aiEmbeddings        AiEmbedding[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  // Momento del último cambio de contraseña (auditoría + invalidación inmediata de access tokens, SEC4).
  passwordChangedAt DateTime?
  // Lockout por cuenta (SEC4): contador de fallos consecutivos y, en su caso, fin del bloqueo.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Obliga a cambiar la contraseña en el próximo acceso (alta por staff/portal o reset por admin, SEC4).
  mustChangePassword  Boolean   @default(false)
  // Email verificado: anti-bots. Auto-registro (registerTenant) nace false y se bloquea hasta confirmar;
  // los invitados quedan verificados al activar su cuenta por el enlace del correo (prueba de posesión).
  emailVerified       Boolean   @default(false)
  // Tarifas del letrado (rate card): facturación (autorellena el parte de horas) y coste/hora interno
  // (sueldo cargado) para calcular el MARGEN real por expediente. Nullable = sin tarifa configurada.
  billRate     Decimal? @db.Decimal(18, 2)
  costRate     Decimal? @db.Decimal(18, 2)
  // Recordatorios de plazos por correo: interruptor del USUARIO (self-service). En false, este usuario
  // no recibe el email del recordatorio (pero sí el aviso in-app). Combina con el flag del despacho.
  deadlineEmailRemindersEnabled Boolean @default(true)
  // MFA (2FA TOTP): secreto base32 CIFRADO (AES-256-GCM) y códigos de respaldo (hashes argon2 en JSON).
  // mfaEnabled false con mfaSecret presente = configuración a medias (pendiente de confirmar el código).
  mfaEnabled     Boolean @default(false)
  mfaSecret      String?
  mfaBackupCodes String?
  // Anti-replay TOTP: último contador de ventana TOTP aceptado; se rechaza reusar un código ya usado.
  lastTotpCounter Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles          UserRole[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]

  // Relaciones de negocio
  responsibleMatters Matter[]          @relation("MatterLawyer")
  clientProfile      Client?           @relation("ClientUser")
  assignedTasks      Task[]            @relation("TaskAssignee")
  timeEntries        TimeEntry[]
  uploadedVersions   DocumentVersion[] @relation("VersionUploader")
  reviews            DocumentReview[]
  messages           Message[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  oauthConnections   OAuthConnection[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  // Código base: CLIENT | LAWYER | FIRM_ADMIN (extensible).
  code      String
  name      String
  createdAt DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id   String @id @default(cuid())
  // p. ej. "matter:read", "invoice:create", "document:approve".
  code String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  // Hash del refresh token (nunca se guarda en claro). Rotación + revocación.
  tokenHash String
  expiresAt DateTime
  // Tope ABSOLUTO de la familia de sesión: la rotación arrastra este valor (no lo extiende), así una
  // sesión activa deja de "deslizar" indefinidamente. Nullable por compatibilidad con sesiones previas
  // (se tratan como legacy y caducan por `expiresAt`). Ver SEC2.
  absoluteExpiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Token de restablecimiento de contraseña (un solo uso). Como RefreshToken, SIN RLS: el flujo público
// de reset opera sin contexto de tenant. Nunca se guarda el token en claro (solo su hash). Ver SEC3.
model PasswordReset {
  id          String    @id @default(cuid())
  userId      String
  // Hash (sha256) del token entregado; el token en claro solo se muestra/envía una vez.
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  // Admin del despacho que lo generó (flujo "reset por admin"); null en autoservicio ("olvidé...").
  createdById String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clientes y Expedientes
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  // Identificador fiscal validado por el ComplianceProvider (NIF/CIF · RNC/Cédula).
  taxId        String
  // Tipo detectado por el provider (NIF/CIF/NIE/RNC/CEDULA). Texto libre para no acoplar al país.
  taxIdKind    String?
  email        String?
  phone        String?
  address      String?
  // Vínculo opcional a un User con rol CLIENT (acceso al portal).
  userId       String?   @unique
  // RGPD/Ley 172-13 — derecho de supresión por ANONIMIZACIÓN (no hard-delete): sello temporal de
  // cuándo se anonimizó la PII. El expediente/facturas/auditoría se PRESERVAN (retención legal). D-022.
  anonymizedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?             @relation("ClientUser", fields: [userId], references: [id])
  matters          Matter[]
  invoices         Invoice[]
  billingSchedules BillingSchedule[]
  kyc              KycProfile?

  @@index([tenantId])
  @@index([tenantId, taxId])
}

// Perfil KYC/AML del cliente (prevención de blanqueo — sujeto obligado en ES). 1:1 con Client.
// `status`: PENDING | IN_REVIEW | APPROVED | REJECTED · `risk`: LOW | MEDIUM | HIGH (validado en DTO).
// Tenant-scoped con RLS fail-closed (activada en la migración). Ver Fase 4.
model KycProfile {
  id               String    @id @default(cuid())
  tenantId         String
  clientId         String    @unique
  status           String    @default("PENDING")
  risk             String    @default("MEDIUM")
  // Persona expuesta políticamente.
  isPep            Boolean   @default(false)
  // Verificaciones del expediente de diligencia debida.
  identityVerified Boolean   @default(false)
  sanctionsChecked Boolean   @default(false)
  notes            String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Matter {
  id        String       @id @default(cuid())
  tenantId  String
  reference String // referencia interna del expediente
  title     String
  type      String // tipo de asunto (texto libre; catálogo en capa de app)
  status    MatterStatus @default(OPEN)
  clientId  String
  lawyerId  String? // abogado responsable
  // Presupuesto de honorarios del expediente (moneda base del despacho). Nullable = sin presupuesto.
  budgetAmount Decimal?  @db.Decimal(18, 2)
  // Parte contraria (UNIVERSAL, no solo litigios): nombre + id fiscal opcional. Alimenta el chequeo
  // deontológico de conflicto en el alta (¿el adversario ya es cliente del despacho?).
  opposingParty      String?
  opposingPartyTaxId String?
  // Datos del PROCEDIMIENTO judicial (solo litigación; opcionales, sección plegable en la UI). Un
  // despacho que solo asesora los deja vacíos y no ve ruido.
  opposingCounsel String? // letrado de la parte contraria
  court           String? // juzgado / tribunal
  caseNumber      String? // nº de autos / procedimiento
  proceduralPhase String? // fase procesal (texto; catálogo en capa de app)
  openedAt  DateTime     @default(now())
  closedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client           Client            @relation(fields: [clientId], references: [id])
  lawyer           User?             @relation("MatterLawyer", fields: [lawyerId], references: [id])
  documents        Document[]
  tasks            Task[]
  timeEntries      TimeEntry[]
  ledgerEntries    LedgerEntry[]
  invoices         Invoice[]
  messages         Message[]
  retainerAccount  RetainerAccount?
  billingSchedules BillingSchedule[]
  emails           MatterEmail[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Documentos + versionado + revisión
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter   Matter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([tenantId])
  @@index([tenantId, matterId])
}

// Plantilla de documento del despacho (contrato/escrito) con campos combinados {{cliente.nombre}}…
// Tenant-scoped con RLS (la migración activa ENABLE/FORCE + política fail-closed). Ver Fase 3.
model DocumentTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  // Cuerpo con marcadores {{campo}} que se sustituyen al generar (cliente/expediente/despacho).
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model DocumentVersion {
  id           String               @id @default(cuid())
  tenantId     String
  documentId   String
  version      Int
  // Clave del objeto en el StorageProvider (S3/MinIO/local).
  storageKey   String
  mimeType     String
  sizeBytes    Int
  // Hash del contenido (integridad).
  contentHash  String
  reviewStatus DocumentReviewStatus @default(PENDING)
  uploadedById String
  createdAt    DateTime             @default(now())

  // tenantId es escalar (sin relación a Tenant) para el filtrado por tenant; ver DocumentReview.
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User               @relation("VersionUploader", fields: [uploadedById], references: [id])
  reviews    DocumentReview[]
  signatures SignatureRequest[]

  @@unique([documentId, version])
  @@index([tenantId])
  @@index([tenantId, documentId])
}

model DocumentReview {
  id         String               @id @default(cuid())
  tenantId   String
  versionId  String
  reviewerId String
  status     DocumentReviewStatus
  comment    String?
  createdAt  DateTime             @default(now())

  version  DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewer User            @relation(fields: [reviewerId], references: [id])

  @@index([tenantId])
  @@index([versionId])
}

// Solicitud de firma electrónica (Signaturit) sobre una versión concreta de documento. El estado
// es String (no enum) — STUBBED/PENDING al solicitar (adaptador listo, sin transmisión real) y
// SIGNED/DECLINED/EXPIRED/CANCELED por callback verificado. Tenant-scoped con RLS (la migración
// activa ENABLE/FORCE + política fail-closed). `documentId`/`matterId`/`requestedById` son escalares
// (sin relación, como DocumentVersion.tenantId) para filtrar; el ciclo de vida cuelga de la versión.
model SignatureRequest {
  id            String    @id @default(cuid())
  tenantId      String
  documentId    String
  versionId     String
  matterId      String
  provider      String    @default("signaturit")
  externalId    String
  status        String    @default("PENDING")
  signerName    String
  signerEmail   String
  signUrl       String?
  detail        String?
  requestedById String
  requestedAt   DateTime  @default(now())
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  version DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, documentId])
  @@index([tenantId, matterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tareas y tiempo
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id           String     @id @default(cuid())
  tenantId     String
  matterId     String?
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  // Si la tarea nace de un plazo procesal calculado, se guarda el tipo y metadatos.
  deadlineType String?
  // true si dueDate proviene de getProceduralDeadlines (vínculo a plazo procesal).
  isProcedural Boolean    @default(false)
  // LexNET-lite: registro de la notificación de la que nace el plazo — referencia (acuse/nº) y fecha
  // de notificación (inicio del cómputo). Nullable: solo en plazos creados desde una notificación.
  notificationRef String?
  notifiedAt      DateTime?
  assigneeId   String?
  // Deduplicación de recordatorios de plazo: la fecha límite para la que ya se avisó y la ventana
  // más urgente (días de antelación) ya notificada. Si dueDate cambia, el avisador detecta el desfase
  // y vuelve a avisar; sólo se notifica una ventana más urgente (menor) que la última registrada.
  lastRemindedForDueDate DateTime?
  lastReminderWindow     Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
  @@index([tenantId, dueDate])
}

model TimeEntry {
  id          String   @id @default(cuid())
  tenantId    String
  matterId    String
  userId      String
  description String
  // Minutos trabajados.
  minutes     Int
  // Tarifa por hora aplicada (Decimal para evitar floats).
  hourlyRate  Decimal  @db.Decimal(18, 2)
  // true cuando ya se ha trasladado al ledger / facturado.
  billed      Boolean  @default(false)
  workedAt    DateTime
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Ledger transparente + Facturación
// ─────────────────────────────────────────────────────────────────────────────

model LedgerEntry {
  id             String          @id @default(cuid())
  tenantId       String
  matterId       String
  type           LedgerEntryType
  description    String
  // Importe con signo según convención de tipo (provisión +, suplido −, etc.).
  amount         Decimal         @db.Decimal(18, 2)
  currency       Currency
  // Factura asociada cuando type = INVOICE/PAYMENT.
  invoiceId      String?
  // Flujo de aprobación de costes: APPROVED por defecto; un coste propuesto por letrado nace PROPOSED.
  approvalStatus ApprovalStatus  @default(APPROVED)
  // Usuario que propuso el coste (cuando approvalStatus != APPROVED por defecto).
  proposedById   String?
  // Usuario admin que resolvió (aprobó/rechazó) la propuesta.
  resolvedById   String?
  // Nota del proponente o del que resuelve.
  approvalNote   String?
  // Justificante del gasto (foto del ticket/tasa): clave en el StorageProvider + metadatos. Nullable.
  receiptKey     String?
  receiptName    String?
  receiptMime    String?
  occurredAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter  Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
  @@index([tenantId, occurredAt])
}

model Invoice {
  id        String        @id @default(cuid())
  tenantId  String
  matterId  String
  clientId  String
  number    String
  status    InvoiceStatus @default(DRAFT)
  issueDate DateTime
  // Vencimiento del cobro (issueDate + plazo de pago). Base de "vencidas" y dunning.
  dueDate   DateTime?
  // Momento en que la factura quedó cobrada por completo (status = PAID).
  paidAt    DateTime?
  // Moneda de ESTA factura (elegible por el despacho: EUR/USD/DOP). Por defecto, la del tenant.
  currency  Currency
  // Formato fiscal/presentación de ESTA factura (es = España/Verifactu · do = RD/e-CF). Lo elige el
  // despacho por factura, DESACOPLADO de la jurisdicción del tenant. Por defecto, la del tenant.
  invoiceFormat Jurisdiction

  // Totales neutrales calculados por el provider (Decimal, no float).
  taxableBase        Decimal @db.Decimal(18, 2)
  taxAmount          Decimal @db.Decimal(18, 2)
  withholdingAmount  Decimal @default(0) @db.Decimal(18, 2)
  // Código de retención aplicado (p. ej. "IRPF_GENERAL" en ES), si lo hubo. Se persiste para poder
  // EMITIR una rectificativa que reverse el anticipo de forma exacta (misma retención). Null = sin retención.
  withholdingTaxCode String?
  total              Decimal @db.Decimal(18, 2)
  // Importe cobrado acumulado (soporta cobros parciales). 0 hasta el primer cobro.
  amountPaid         Decimal @default(0) @db.Decimal(18, 2)

  // Registro fiscal específico del país (Verifactu / e-CF) como JSON OPACO al núcleo.
  complianceRecord   Json?
  // Formato del registro: "VERIFACTU" | "ECF".
  complianceFormat   String?
  // Hash del registro fiscal (encadenamiento Verifactu).
  recordHash         String?
  // Hash del registro inmediatamente anterior (cadena inalterable).
  previousRecordHash String?

  // Estado de la transmisión del e-CF a la DGII (RD). NOT_APPLICABLE para ES/Verifactu; STUBBED si la
  // transmisión está apagada; PENDING/ACCEPTED/REJECTED según el acuse de la DGII. TrackId = id del envío.
  ecfStatus       EcfStatus @default(NOT_APPLICABLE)
  ecfTrackId      String?
  ecfStatusDetail String?
  ecfSubmittedAt  DateTime?

  // Tipo de documento: NORMAL | RECTIFICATIVA (D-027 (c)). Una rectificativa referencia la factura que
  // corrige (`rectifiesInvoiceId`), su causa y su método (sustitución/diferencias). Las facturas de
  // anticipo quedan inmutables; la rectificativa es un registro nuevo encadenado.
  documentType        InvoiceDocumentType @default(NORMAL)
  rectifiesInvoiceId  String?
  rectificationReason String?
  rectificationMode   RectificationMode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter              Matter               @relation(fields: [matterId], references: [id])
  client              Client               @relation(fields: [clientId], references: [id])
  lines               InvoiceLine[]
  ledger              LedgerEntry[]
  payments            Payment[]
  dunningReminders    DunningReminder[]
  retainerEntries     RetainerEntry[]
  billingInstallments BillingInstallment[]
  // Auto-relación: la factura rectificada y las rectificativas que la corrigen (Verifactu: cadena de
  // sustitución). `rectifies` apunta a la factura original; `rectifiedBy` son sus rectificativas.
  rectifies           Invoice?             @relation("InvoiceRectification", fields: [rectifiesInvoiceId], references: [id])
  rectifiedBy         Invoice[]            @relation("InvoiceRectification")

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

/// Estado de la transmisión del e-CF a la DGII (RD).
enum EcfStatus {
  NOT_APPLICABLE // No aplica (ES/Verifactu o factura no electrónica).
  STUBBED // Transmisión apagada (sin DGII_ENV o sin certificado): no se transmitió.
  PENDING // Enviado a la DGII, pendiente de acuse (o pendiente de transmitir).
  ACCEPTED // Aceptado por la DGII.
  REJECTED // Rechazado por la DGII (ver ecfStatusDetail).
}

/// Vista guardada (preset de filtros) PRIVADA por usuario, por ámbito (facturas/tareas/expedientes).
model SavedView {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String // dueño de la vista (privada)
  scope     String // "invoices" | "tasks" | "matters"
  name      String
  filters   Json // preset de filtros, opaco al núcleo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, scope])
}

// Plantilla/snippet de correo del despacho (respuestas recurrentes), compartida por todo el despacho.
model EmailSnippet {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  subject   String? // asunto opcional
  body      String // cuerpo de la plantilla
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Cobro sobre una factura. Soporta cobros parciales (varios Payment por factura) y conciliación con
// pasarela (Stripe en ES) o registro manual. El núcleo es agnóstico de pasarela: `method`/`providerRef`
// identifican el origen; `metadata` guarda el payload opaco del proveedor. Ver D-024.
model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  invoiceId   String
  amount      Decimal       @db.Decimal(18, 2)
  currency    Currency
  status      PaymentStatus @default(SUCCEEDED)
  // Origen del cobro: "MANUAL" | "STRIPE" | … (lo fija el adaptador de pasarela).
  method      String
  // Identificador externo del cobro en la pasarela (p. ej. PaymentIntent de Stripe). Para idempotencia.
  providerRef String?
  note        String?
  // Payload/datos de conciliación específicos del proveedor (opaco al núcleo).
  metadata    Json?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  retainerEntries     RetainerEntry[]
  billingInstallments BillingInstallment[]

  @@unique([tenantId, providerRef])
  @@index([tenantId])
  @@index([tenantId, invoiceId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 2)
  // Código de impuesto aplicado (de getTaxRates), p. ej. "IVA_STANDARD" | "ITBIS_STANDARD".
  taxCode     String
  lineTotal   Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dunning (recordatorios de cobro de facturas vencidas)
// ─────────────────────────────────────────────────────────────────────────────

// Regla de dunning configurable por despacho: "a los N días del vencimiento, dispara un recordatorio
// de tal severidad por tal canal". El escalado se expresa con varias reglas de offsetDays creciente
// (p. ej. +1 REMINDER, +7 WARNING, +15 FINAL). Jurisdicción-aware vía el tenant (idioma/tono en UI).
model DunningRule {
  id         String          @id @default(cuid())
  tenantId   String
  // Días tras la fecha de vencimiento (dueDate) en los que aplica esta etapa. Único por tenant.
  offsetDays Int
  severity   DunningSeverity @default(REMINDER)
  // Canal de entrega de esta etapa. Hoy IN_APP; EMAIL/SMS quedan listos para Fase 2.
  channel    DunningChannel  @default(IN_APP)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminders DunningReminder[]

  @@unique([tenantId, offsetDays])
  @@index([tenantId])
}

// Recordatorio concreto generado para una factura en una etapa. Es el ancla de IDEMPOTENCIA del motor
// (único por factura+offset: no se vuelve a generar la misma etapa) y el registro de "qué se disparó".
// La auditoría inmutable se sigue escribiendo aparte en AuditLog; este modelo es el estado operativo.
model DunningReminder {
  id           String                @id @default(cuid())
  tenantId     String
  invoiceId    String
  // Regla que lo originó (null para recordatorios manuales ad-hoc). Si se borra la regla, queda el histórico.
  ruleId       String?
  // Instantánea de la etapa al generarse (estable aunque la regla cambie/desaparezca).
  offsetDays   Int
  severity     DunningSeverity
  channel      DunningChannel        @default(IN_APP)
  status       DunningReminderStatus @default(SCHEDULED)
  // Fecha en la que la etapa vence (dueDate + offsetDays).
  scheduledFor DateTime
  sentAt       DateTime?
  metadata     Json?
  createdAt    DateTime              @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  rule    DunningRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, invoiceId, offsetDays])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Provisión de fondos / retainer (anticipos cobrados, saldo por cliente)
// ─────────────────────────────────────────────────────────────────────────────

// Saldo de provisión de fondos POR EXPEDIENTE/ASUNTO (práctica ES: la provisión se segrega por asunto,
// no por cliente). El "saldo por cliente" se DERIVA sumando las cuentas de sus asuntos (vista/cálculo,
// no una tabla nueva). Posible extensión futura (NO ahora): un retainer general no ligado a asunto.
//
// MONO-MONEDA por tenant: `currency` = moneda del tenant, fijada al crear la cuenta; todos los
// movimientos van en esa moneda (un guard en R2/R3 rechaza importes en otra). Si hiciera falta
// multi-moneda, se añadiría `currency` al `RetainerEntry`; NO ahora. Ver D-026.
//
// `balance` es un saldo CACHEADO que se actualiza de forma transaccional con cada `RetainerEntry`
// (con SELECT … FOR UPDATE sobre la cuenta; invariante balance == Σ(entries)); los movimientos son la
// fuente auditada. Tratamiento fiscal del cobro: ver D-026 (pendiente de ratificación).
model RetainerAccount {
  id        String   @id @default(cuid())
  tenantId  String
  // Un retainer por expediente (relación 1-1). `matterId` único satisface el 1-1; el tenant se
  // mantiene para el aislamiento RLS.
  matterId  String   @unique
  currency  Currency
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter  Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  entries RetainerEntry[]

  @@index([tenantId])
}

// Movimiento auditado del saldo de provisión. `amount` lleva su signo (DEPOSIT +, APPLICATION −,
// REFUND −, ADJUSTMENT ±) en la moneda de la cuenta (mono-moneda del tenant). `invoiceId` en
// APPLICATION; `paymentId` enlaza el Payment que originó el movimiento (depósito / aplicación a factura).
model RetainerEntry {
  id        String               @id @default(cuid())
  tenantId  String
  accountId String
  type      RetainerMovementType
  // Naturaleza fiscal del depósito (solo en DEPOSIT): SUPLIDO/GENERICO en R2; ANTICIPO en R2b. Null en
  // APPLICATION/REFUND/ADJUSTMENT.
  kind      ProvisionKind?
  amount    Decimal              @db.Decimal(18, 2)
  invoiceId String?
  paymentId String?
  note      String?
  createdAt DateTime             @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account RetainerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoice Invoice?        @relation(fields: [invoiceId], references: [id])
  payment Payment?        @relation(fields: [paymentId], references: [id])

  @@index([tenantId, accountId])
  @@index([tenantId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Facturación programada: recurrente (iguala) + planes de pago (fraccionamiento)
// ─────────────────────────────────────────────────────────────────────────────

// Plan de facturación programada de un expediente. Un único motor cubre RECURRING (1 factura por
// periodo) e INSTALLMENTS (fraccionar un importe; fiscalidad por `fiscalMode`). El cron procesa los
// vencimientos (`nextRunAt`) y, en cada emisión, pasa por `buildInvoiceRecord` (serie + Verifactu/e-CF +
// QR; sin atajos). RLS fail-closed. Ver PLAN (Ítem recurrente) y D-026/D-027.
model BillingSchedule {
  id                 String                @id @default(cuid())
  tenantId           String
  matterId           String
  clientId           String
  currency           Currency
  type               BillingScheduleType
  // Solo relevante en INSTALLMENTS; en RECURRING cada periodo es un servicio prestado (factura normal).
  fiscalMode         BillingFiscalMode     @default(SERVICE_RENDERED)
  status             BillingScheduleStatus @default(ACTIVE)
  // Plantilla de líneas (concepto/cantidad/precio/taxCode) como JSON neutral. El provider fiscal calcula
  // impuestos al emitir; el núcleo no calcula IVA/ITBIS en cliente. Mono-moneda = `currency`.
  lines              Json
  // Retención (p. ej. IRPF_GENERAL en ES) aplicable a cada emisión, si procede.
  withholdingTaxCode String?
  // RECURRING: cadencia = cada `intervalCount` × `intervalUnit`; `occurrences` = nº de emisiones
  // (null = abierto, hasta pausar/cancelar).
  intervalUnit       BillingInterval?
  intervalCount      Int                   @default(1)
  occurrences        Int?
  // INSTALLMENTS: nº de cuotas del fraccionamiento.
  installmentCount   Int?
  startDate          DateTime
  // Próximo vencimiento a procesar por el cron; null cuando COMPLETED/CANCELLED.
  nextRunAt          DateTime?
  note               String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter       Matter               @relation(fields: [matterId], references: [id], onDelete: Cascade)
  client       Client               @relation(fields: [clientId], references: [id])
  installments BillingInstallment[]

  @@index([tenantId])
  @@index([tenantId, matterId])
  @@index([tenantId, status, nextRunAt])
}

// Cuota/periodo concreto de un plan. En RECURRING cada fila es un periodo (su factura propia); en
// INSTALLMENTS es una cuota (cobro contra la factura única en SERVICE_RENDERED, o su factura de anticipo
// en ADVANCE). `invoiceId`/`paymentId` enlazan el documento fiscal y el cobro. RLS fail-closed.
model BillingInstallment {
  id         String                   @id @default(cuid())
  tenantId   String
  scheduleId String
  // Orden dentro del plan (1..N). Único por plan.
  sequence   Int
  dueDate    DateTime
  // Importe BASE planificado de la cuota/periodo (mono-moneda del plan); los impuestos los calcula el
  // provider al emitir.
  amount     Decimal                  @db.Decimal(18, 2)
  status     BillingInstallmentStatus @default(SCHEDULED)
  invoiceId  String?
  paymentId  String?
  emittedAt  DateTime?
  paidAt     DateTime?
  createdAt  DateTime                 @default(now())

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule BillingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  invoice  Invoice?        @relation(fields: [invoiceId], references: [id])
  payment  Payment?        @relation(fields: [paymentId], references: [id])

  @@unique([scheduleId, sequence])
  @@index([tenantId, scheduleId])
  @@index([tenantId, status, dueDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notificaciones, chat y auditoría
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String?
  // Metadatos arbitrarios (ids relacionados).
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Message {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId, matterId])
}

// AuditLog inmutable (append-only a nivel de aplicación; endurecible con trigger/RLS en Postgres).
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  // Usuario que ejecuta la acción (puede ser null para acciones del sistema).
  actorId    String?
  action     String // p. ej. "invoice.issued", "document.approved"
  entityType String
  entityId   String
  // Instantánea de datos relevantes (sin secretos).
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

// Captación / mini-CRM: prospecto (lead) en el embudo del despacho. Se crea desde el formulario público
// de intake o a mano; al CONVERTIR se crea su Cliente (y opcionalmente Expediente) y se enlaza aquí.
model Lead {
  id                String    @id @default(cuid())
  tenantId          String
  name              String
  email             String?
  phone             String?
  company           String?
  // Asunto/consulta del prospecto y notas internas.
  subject           String?
  notes             String?
  // Origen: "intake" (formulario público) | "manual" | "referido" | "web"...
  source            String    @default("manual")
  // Embudo: NEW | CONTACTED | QUALIFIED | CONVERTED | LOST (ver LeadStatus en @legalflow/domain).
  status            String    @default("NEW")
  estimatedValue    Decimal?  @db.Decimal(18, 2)
  assignedToId      String?
  // Trazabilidad de conversión.
  convertedClientId String?
  convertedMatterId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// Conexión OAuth de un usuario con un proveedor externo (Google: Calendar + Gmail). Tokens CIFRADOS
// en reposo (AES-256-GCM con DATA_ENCRYPTION_KEY). Una conexión por (usuario, proveedor).
model OAuthConnection {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  provider      String // 'google' | 'microsoft'
  externalEmail String?
  scopes        String    @default("")
  accessToken   String // cifrado (base64 del blob)
  refreshToken  String? // cifrado
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([tenantId])
}

// Correo de un expediente: enviado desde la app (OUT) o adjuntado desde la bandeja (IN), vía Gmail.
// La correspondencia queda en el expediente. `gmailId` evita adjuntar dos veces el mismo mensaje.
model MatterEmail {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String
  userId    String? // quién lo envió/adjuntó
  direction String // 'IN' | 'OUT'
  gmailId   String?
  fromAddr  String
  toAddr    String
  subject   String?
  snippet   String?  @db.Text
  sentAt    DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([tenantId, matterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Índice semántico para búsqueda con IA (RAG)
// ─────────────────────────────────────────────────────────────────────────────
// Fragmentos de expedientes/documentos con su vector de embedding. La similitud coseno se calcula en la
// app sobre los vectores del tenant (escala de despacho; sin pgvector, sin extensión). Tenant-scoped con
// RLS fail-closed. Se re-indexa al cambiar el contenido o el modelo de embeddings (`model`).
model AiEmbedding {
  id         String   @id @default(cuid())
  tenantId   String
  kind       String // 'matter' | 'document'
  refId      String // id del expediente/documento de origen
  refLabel   String // etiqueta legible (referencia/título o nombre del documento)
  chunkIndex Int      @default(0)
  content    String // fragmento de texto (se devuelve como excerpt/cita)
  embedding  Float[] // vector de embedding; similitud coseno en la app
  model      String // modelo de embeddings usado (para invalidar al cambiarlo)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, kind, refId])
}
