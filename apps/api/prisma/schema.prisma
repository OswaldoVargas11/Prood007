// LegalFlow — esquema de dominio (Prisma + PostgreSQL).
//
// MULTI-TENANCY: aislamiento row-level por `tenantId` en toda tabla de negocio, con índices
// compuestos (tenantId, ...). Postgres RLS ACTIVA como defensa en profundidad (ver DECISIONS
// D-004 y D-013): políticas por current_setting('app.tenant_id'); el runtime conecta como rol de
// mínimo privilegio y fija el GUC por request.
//
// AGNOSTICISMO: este esquema NO codifica ninguna ley concreta. Los campos fiscales específicos
// de cada país viajan en `Invoice.complianceRecord` (JSON opaco) generado por el ComplianceProvider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // url = rol de aplicación de mínimo privilegio (sin superusuario) → RLS SÍ se aplica en runtime.
  url       = env("DATABASE_URL")
  // directUrl = rol propietario/privilegiado, usado SOLO por Prisma Migrate (DDL, roles, RLS).
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (espejo de @legalflow/domain)
// ─────────────────────────────────────────────────────────────────────────────

enum Jurisdiction {
  es
  do
}

enum Currency {
  EUR
  DOP
}

enum MatterStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum DocumentReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum LedgerEntryType {
  PROVISION
  DISBURSEMENT
  TIME_FEE
  FEE
  INVOICE
  PAYMENT
  ADJUSTMENT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIAL
  OVERDUE
  PAID
  CANCELLED
}

// Estado de aprobación de un apunte del ledger (flujo de aprobación de costes).
// Por defecto APPROVED (los apuntes normales no requieren aprobación); un coste propuesto por un
// letrado nace PROPOSED y el admin lo aprueba o rechaza.
enum ApprovalStatus {
  PROPOSED
  APPROVED
  REJECTED
}

// Estado de un cobro (Payment) sobre una factura.
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

// Canal de entrega de un recordatorio de cobro (dunning). Hoy solo IN_APP; EMAIL/SMS reservados para
// Fase 2 (punto de integración, sin canal construido aún). Ver enums de @legalflow/domain.
enum DunningChannel {
  IN_APP
  EMAIL
  SMS
}

// Severidad/escalado del recordatorio: recordatorio → aviso → aviso final, según crece el retraso.
enum DunningSeverity {
  REMINDER
  WARNING
  FINAL
}

// Estado de un recordatorio concreto: planificado, entregado, omitido (factura cobrada antes), fallido.
enum DunningReminderStatus {
  SCHEDULED
  SENT
  SKIPPED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy & Auth / RBAC
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id                    String       @id @default(cuid())
  name                  String
  // Identificador fiscal del despacho emisor (NIF/CIF en ES, RNC en RD). Necesario para facturar.
  taxId                 String?
  jurisdiction          Jurisdiction
  currency              Currency
  locale                String       @default("es-ES")
  // Licencia / suscripción: plan y plazas contratadas (asientos) por rol de staff.
  plan                  String       @default("Profesional")
  // Máximo de usuarios ACTIVOS por rol (la licencia del despacho).
  maxAdmins             Int          @default(2)
  maxLawyers            Int          @default(5)
  // Serie fiscal: prefijo de la numeración de facturas (p. ej. "FAC", "A").
  invoiceSeries         String       @default("FAC")
  // Festivos locales del despacho: array JSON [{ date: "yyyy-mm-dd", name }] que afina el cómputo de
  // plazos procesales (se suman a los festivos nacionales de la jurisdicción).
  holidays              Json?
  // Certificado digital del despacho (para firmar/emitir). Metadatos; el fichero va al StorageProvider.
  certificateName       String?
  certificateKey        String?
  certificateUploadedAt DateTime?
  // RGPD/Ley 172-13 — gobernanza de datos (D-022): región de residencia de datos del despacho
  // (p. ej. "EU" para ES; a definir para RD) y política de conservación configurable en meses. La
  // RETENCIÓN es metadato/política (la conservación legal prevalece sobre el borrado); no auto-purga.
  dataRegion            String?
  retentionMonths       Int?
  // Cuenta conectada de Stripe (Connect Standard) del despacho. El cobro online va a SU cuenta, no a la
  // plataforma (evita ser transmisor de fondos). Vacío = el despacho aún no ha conectado Stripe. Ver D-024.
  stripeAccountId       String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  users            User[]
  roles            Role[]
  clients          Client[]
  matters          Matter[]
  documents        Document[]
  tasks            Task[]
  timeEntries      TimeEntry[]
  ledgerEntries    LedgerEntry[]
  invoices         Invoice[]
  payments         Payment[]
  dunningRules     DunningRule[]
  dunningReminders DunningReminder[]
  notifications    Notification[]
  messages         Message[]
  auditLogs        AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  refreshTokens RefreshToken[]

  // Relaciones de negocio
  responsibleMatters Matter[]          @relation("MatterLawyer")
  clientProfile      Client?           @relation("ClientUser")
  assignedTasks      Task[]            @relation("TaskAssignee")
  timeEntries        TimeEntry[]
  uploadedVersions   DocumentVersion[] @relation("VersionUploader")
  reviews            DocumentReview[]
  messages           Message[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  // Código base: CLIENT | LAWYER | FIRM_ADMIN (extensible).
  code      String
  name      String
  createdAt DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id   String @id @default(cuid())
  // p. ej. "matter:read", "invoice:create", "document:approve".
  code String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  // Hash del refresh token (nunca se guarda en claro). Rotación + revocación.
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clientes y Expedientes
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  // Identificador fiscal validado por el ComplianceProvider (NIF/CIF · RNC/Cédula).
  taxId        String
  // Tipo detectado por el provider (NIF/CIF/NIE/RNC/CEDULA). Texto libre para no acoplar al país.
  taxIdKind    String?
  email        String?
  phone        String?
  address      String?
  // Vínculo opcional a un User con rol CLIENT (acceso al portal).
  userId       String?   @unique
  // RGPD/Ley 172-13 — derecho de supresión por ANONIMIZACIÓN (no hard-delete): sello temporal de
  // cuándo se anonimizó la PII. El expediente/facturas/auditoría se PRESERVAN (retención legal). D-022.
  anonymizedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User?     @relation("ClientUser", fields: [userId], references: [id])
  matters  Matter[]
  invoices Invoice[]

  @@index([tenantId])
  @@index([tenantId, taxId])
}

model Matter {
  id        String       @id @default(cuid())
  tenantId  String
  reference String // referencia interna del expediente
  title     String
  type      String // tipo de asunto (texto libre; catálogo en capa de app)
  status    MatterStatus @default(OPEN)
  clientId  String
  lawyerId  String? // abogado responsable
  openedAt  DateTime     @default(now())
  closedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id])
  lawyer        User?         @relation("MatterLawyer", fields: [lawyerId], references: [id])
  documents     Document[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  ledgerEntries LedgerEntry[]
  invoices      Invoice[]
  messages      Message[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Documentos + versionado + revisión
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter   Matter            @relation(fields: [matterId], references: [id], onDelete: Cascade)
  versions DocumentVersion[]

  @@index([tenantId])
  @@index([tenantId, matterId])
}

model DocumentVersion {
  id           String               @id @default(cuid())
  tenantId     String
  documentId   String
  version      Int
  // Clave del objeto en el StorageProvider (S3/MinIO/local).
  storageKey   String
  mimeType     String
  sizeBytes    Int
  // Hash del contenido (integridad).
  contentHash  String
  reviewStatus DocumentReviewStatus @default(PENDING)
  uploadedById String
  createdAt    DateTime             @default(now())

  // tenantId es escalar (sin relación a Tenant) para el filtrado por tenant; ver DocumentReview.
  document   Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User             @relation("VersionUploader", fields: [uploadedById], references: [id])
  reviews    DocumentReview[]

  @@unique([documentId, version])
  @@index([tenantId])
  @@index([tenantId, documentId])
}

model DocumentReview {
  id         String               @id @default(cuid())
  tenantId   String
  versionId  String
  reviewerId String
  status     DocumentReviewStatus
  comment    String?
  createdAt  DateTime             @default(now())

  version  DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewer User            @relation(fields: [reviewerId], references: [id])

  @@index([tenantId])
  @@index([versionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tareas y tiempo
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id           String     @id @default(cuid())
  tenantId     String
  matterId     String?
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  // Si la tarea nace de un plazo procesal calculado, se guarda el tipo y metadatos.
  deadlineType String?
  // true si dueDate proviene de getProceduralDeadlines (vínculo a plazo procesal).
  isProcedural Boolean    @default(false)
  assigneeId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
  @@index([tenantId, dueDate])
}

model TimeEntry {
  id          String   @id @default(cuid())
  tenantId    String
  matterId    String
  userId      String
  description String
  // Minutos trabajados.
  minutes     Int
  // Tarifa por hora aplicada (Decimal para evitar floats).
  hourlyRate  Decimal  @db.Decimal(18, 2)
  // true cuando ya se ha trasladado al ledger / facturado.
  billed      Boolean  @default(false)
  workedAt    DateTime
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Ledger transparente + Facturación
// ─────────────────────────────────────────────────────────────────────────────

model LedgerEntry {
  id             String          @id @default(cuid())
  tenantId       String
  matterId       String
  type           LedgerEntryType
  description    String
  // Importe con signo según convención de tipo (provisión +, suplido −, etc.).
  amount         Decimal         @db.Decimal(18, 2)
  currency       Currency
  // Factura asociada cuando type = INVOICE/PAYMENT.
  invoiceId      String?
  // Flujo de aprobación de costes: APPROVED por defecto; un coste propuesto por letrado nace PROPOSED.
  approvalStatus ApprovalStatus  @default(APPROVED)
  // Usuario que propuso el coste (cuando approvalStatus != APPROVED por defecto).
  proposedById   String?
  // Usuario admin que resolvió (aprobó/rechazó) la propuesta.
  resolvedById   String?
  // Nota del proponente o del que resuelve.
  approvalNote   String?
  occurredAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter  Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, matterId])
  @@index([tenantId, occurredAt])
}

model Invoice {
  id        String        @id @default(cuid())
  tenantId  String
  matterId  String
  clientId  String
  number    String
  status    InvoiceStatus @default(DRAFT)
  issueDate DateTime
  // Vencimiento del cobro (issueDate + plazo de pago). Base de "vencidas" y dunning.
  dueDate   DateTime?
  // Momento en que la factura quedó cobrada por completo (status = PAID).
  paidAt    DateTime?
  currency  Currency

  // Totales neutrales calculados por el provider (Decimal, no float).
  taxableBase       Decimal @db.Decimal(18, 2)
  taxAmount         Decimal @db.Decimal(18, 2)
  withholdingAmount Decimal @default(0) @db.Decimal(18, 2)
  total             Decimal @db.Decimal(18, 2)
  // Importe cobrado acumulado (soporta cobros parciales). 0 hasta el primer cobro.
  amountPaid        Decimal @default(0) @db.Decimal(18, 2)

  // Registro fiscal específico del país (Verifactu / e-CF) como JSON OPACO al núcleo.
  complianceRecord   Json?
  // Formato del registro: "VERIFACTU" | "ECF".
  complianceFormat   String?
  // Hash del registro fiscal (encadenamiento Verifactu).
  recordHash         String?
  // Hash del registro inmediatamente anterior (cadena inalterable).
  previousRecordHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter           Matter            @relation(fields: [matterId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id])
  lines            InvoiceLine[]
  ledger           LedgerEntry[]
  payments         Payment[]
  dunningReminders DunningReminder[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

// Cobro sobre una factura. Soporta cobros parciales (varios Payment por factura) y conciliación con
// pasarela (Stripe en ES) o registro manual. El núcleo es agnóstico de pasarela: `method`/`providerRef`
// identifican el origen; `metadata` guarda el payload opaco del proveedor. Ver D-024.
model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  invoiceId   String
  amount      Decimal       @db.Decimal(18, 2)
  currency    Currency
  status      PaymentStatus @default(SUCCEEDED)
  // Origen del cobro: "MANUAL" | "STRIPE" | … (lo fija el adaptador de pasarela).
  method      String
  // Identificador externo del cobro en la pasarela (p. ej. PaymentIntent de Stripe). Para idempotencia.
  providerRef String?
  note        String?
  // Payload/datos de conciliación específicos del proveedor (opaco al núcleo).
  metadata    Json?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([providerRef])
  @@index([tenantId])
  @@index([tenantId, invoiceId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 2)
  // Código de impuesto aplicado (de getTaxRates), p. ej. "IVA_STANDARD" | "ITBIS_STANDARD".
  taxCode     String
  lineTotal   Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dunning (recordatorios de cobro de facturas vencidas)
// ─────────────────────────────────────────────────────────────────────────────

// Regla de dunning configurable por despacho: "a los N días del vencimiento, dispara un recordatorio
// de tal severidad por tal canal". El escalado se expresa con varias reglas de offsetDays creciente
// (p. ej. +1 REMINDER, +7 WARNING, +15 FINAL). Jurisdicción-aware vía el tenant (idioma/tono en UI).
model DunningRule {
  id         String          @id @default(cuid())
  tenantId   String
  // Días tras la fecha de vencimiento (dueDate) en los que aplica esta etapa. Único por tenant.
  offsetDays Int
  severity   DunningSeverity @default(REMINDER)
  // Canal de entrega de esta etapa. Hoy IN_APP; EMAIL/SMS quedan listos para Fase 2.
  channel    DunningChannel  @default(IN_APP)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminders DunningReminder[]

  @@unique([tenantId, offsetDays])
  @@index([tenantId])
}

// Recordatorio concreto generado para una factura en una etapa. Es el ancla de IDEMPOTENCIA del motor
// (único por factura+offset: no se vuelve a generar la misma etapa) y el registro de "qué se disparó".
// La auditoría inmutable se sigue escribiendo aparte en AuditLog; este modelo es el estado operativo.
model DunningReminder {
  id           String                @id @default(cuid())
  tenantId     String
  invoiceId    String
  // Regla que lo originó (null para recordatorios manuales ad-hoc). Si se borra la regla, queda el histórico.
  ruleId       String?
  // Instantánea de la etapa al generarse (estable aunque la regla cambie/desaparezca).
  offsetDays   Int
  severity     DunningSeverity
  channel      DunningChannel        @default(IN_APP)
  status       DunningReminderStatus @default(SCHEDULED)
  // Fecha en la que la etapa vence (dueDate + offsetDays).
  scheduledFor DateTime
  sentAt       DateTime?
  metadata     Json?
  createdAt    DateTime              @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  rule    DunningRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, invoiceId, offsetDays])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notificaciones, chat y auditoría
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String?
  // Metadatos arbitrarios (ids relacionados).
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Message {
  id        String   @id @default(cuid())
  tenantId  String
  matterId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId, matterId])
}

// AuditLog inmutable (append-only a nivel de aplicación; endurecible con trigger/RLS en Postgres).
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  // Usuario que ejecuta la acción (puede ser null para acciones del sistema).
  actorId    String?
  action     String // p. ej. "invoice.issued", "document.approved"
  entityType String
  entityId   String
  // Instantánea de datos relevantes (sin secretos).
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}
