# ─── Base de datos (Postgres / Prisma) ───────────────────────────────
# Tres roles para que RLS (fail-closed, D-013/D-020) sea efectiva:
#  - DATABASE_URL        → rol de mínimo privilegio `legalflow_app` (runtime): RLS SÍ se aplica.
#  - DIRECT_DATABASE_URL → rol propietario/privilegiado: SOLO para Prisma Migrate (DDL, roles, RLS).
#  - SYSTEM_DATABASE_URL → rol `legalflow_system` (BYPASSRLS): SOLO rutas cross-tenant legítimas
#                          (login/registro/carga de token). "Joya de la corona": salta TODO el
#                          aislamiento → secreto fuerte, aparte, nunca logueado. OBLIGATORIO en
#                          producción (si falta, el arranque falla). En dev/CI, si se omite cae a
#                          DIRECT_DATABASE_URL con aviso (no romper dev pesa más que separar roles).
DATABASE_URL="postgresql://legalflow_app:legalflow_app@localhost:5432/legalflow?schema=public"
DIRECT_DATABASE_URL="postgresql://legalflow:legalflow@localhost:5432/legalflow?schema=public"
SYSTEM_DATABASE_URL="postgresql://legalflow_system:legalflow_system@localhost:5432/legalflow?schema=public"

# ─── API (NestJS) ────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# JWT — usa secretos largos y distintos en producción
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_REFRESH_TTL="7d"

# ─── Realtime / cache (Redis) ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Storage (S3-compatible / MinIO en dev) ──────────────────────────
STORAGE_DRIVER="minio"            # minio | s3 | local
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="legalflow"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_LOCAL_PATH="./storage"    # usado solo si STORAGE_DRIVER=local

# Cifrado en reposo del contenido de documentos (AES-256-GCM, D-021). Clave de 32 bytes en base64.
# OBLIGATORIO en producción (sin clave el arranque falla); en dev/CI, si se omite, se guarda en claro.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY="<genera-una-clave-de-32-bytes-en-base64-con-el-comando-de-arriba>"
# Claves RETIRADAS (base64, separadas por coma) para ROTAR la clave maestra sin downtime (D6-001): pon la
# clave vieja aquí y la nueva en DATA_ENCRYPTION_KEY → lo nuevo se cifra con la nueva, lo viejo aún se
# descifra con la vieja; re-cifra en segundo plano y luego retira la vieja de esta lista. Vacío = sin rotación.
DATA_ENCRYPTION_KEY_RETIRED=""

# ─── Cobro online (Stripe Connect, D-024) ────────────────────────────
# OPCIONAL. Sin STRIPE_SECRET_KEY el cobro online queda DESHABILITADO (el módulo funciona en modo
# manual) — por eso CI no necesita estas claves. Para activarlo en producción:
#  - STRIPE_SECRET_KEY     → clave secreta de la PLATAFORMA (sk_live_… / sk_test_…). "Joya de la corona".
#  - STRIPE_WEBHOOK_SECRET → secreto de firma del endpoint de webhook (whsec_…) para verificar eventos.
#  - APP_PUBLIC_URL        → URL pública del web (para las URLs de retorno del checkout/onboarding).
# El despacho conecta SU cuenta (Connect Standard) desde Ajustes; el dinero va a su cuenta, no a la plataforma.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
APP_PUBLIC_URL="http://localhost:3000"

# ─── Firma electrónica (Signaturit, Fase 5) ──────────────────────────
# OPCIONAL. El adaptador de firma está LISTO pero no transmite (devuelve STUBBED): solicitar firma
# crea la solicitud en estado PENDING sin llamar al proveedor — por eso CI no necesita estas claves.
# Para activar la transmisión real:
#  - SIGNATURE_PROVIDER        → proveedor de firma (por ahora "signaturit"). Por defecto: signaturit.
#  - SIGNATURE_WEBHOOK_SECRET  → secreto HMAC del webhook de Signaturit (verifica la firma del callback).
SIGNATURE_PROVIDER="signaturit"
SIGNATURE_WEBHOOK_SECRET=""

# ─── Integraciones OAuth (Google / Microsoft) ────────────────────────
# OPCIONAL. Conectan la cuenta del usuario para: agenda (Calendar), correo del expediente (Gmail/Outlook)
# e IMPORTAR FICHEROS desde la nube (Google Drive, OneDrive, SharePoint). Sin estas claves los módulos
# responden "no configurado" y la UI oculta los botones — por eso CI no las necesita.
# Guía detallada: GOOGLE_OAUTH_SETUP.md, MICROSOFT_OAUTH_SETUP.md y CLOUD_IMPORT_SETUP.md.
#
# Google (OAuth + Google Picker para Drive):
#   - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET → credenciales OAuth (consola de Google Cloud).
#   - GOOGLE_REDIRECT_URI    → debe coincidir EXACTO con el "Authorized redirect URI" registrado.
#   - GOOGLE_PICKER_API_KEY  → clave de navegador (API key) con la "Picker API" habilitada. Necesaria
#                              para abrir el Google Picker al importar de Drive.
#   - GOOGLE_PROJECT_NUMBER  → número del proyecto de Google Cloud (appId del Picker).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/integrations/google/callback"
GOOGLE_PICKER_API_KEY=""
GOOGLE_PROJECT_NUMBER=""
#
# Microsoft 365 (OAuth + Graph para Outlook/OneDrive/SharePoint):
#   - MS_CLIENT_ID / MS_CLIENT_SECRET → credenciales de la app registrada en Entra ID (Azure).
#   - MS_REDIRECT_URI → debe coincidir EXACTO con el redirect URI registrado.
#   - MS_TENANT       → "common" (multi-tenant) o el GUID/dominio del tenant. Por defecto: common.
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_REDIRECT_URI="http://localhost:4000/api/integrations/microsoft/callback"
MS_TENANT="common"

# ─── Observabilidad (Sentry) ─────────────────────────────────────────
# OPCIONAL. Sin SENTRY_DSN, el SDK queda INERTE (no envía nada) — por eso CI/dev no lo necesitan.
# Para activarlo en la API: crea un proyecto en sentry.io (plataforma Node.js) y pega su DSN aquí.
#   - SENTRY_DSN                 → DSN del proyecto Sentry de la API. Vacío = observabilidad off.
#   - SENTRY_TRACES_SAMPLE_RATE  → muestreo de trazas de rendimiento 0..1 (default 0 = solo errores).
#   - SENTRY_RELEASE             → (opcional) versión desplegada para correlacionar errores.
# Privacidad: sendDefaultPii=false (no se envían cabeceras/cookies/IP/cuerpos). Ver SENTRY_SETUP.md.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_RELEASE=""
# Nivel de los logs estructurados (pino) de la API: trace|debug|info|warn|error. Default: info en prod.
LOG_LEVEL=""
# Sentry del WEB (errores de navegador). Es NEXT_PUBLIC_* → se hornea EN BUILD: hay que pasarlo como
# build-arg al construir la imagen del web (no como secret en runtime). Vacío = SDK fuera del bundle.
# Crea un SEGUNDO proyecto Sentry (plataforma Next.js) para el web. Ver SENTRY_SETUP.md.
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"

# ─── Facturación electrónica RD (e-CF · DGII) ────────────────────────
# OPCIONAL y GATED. Sin DGII_ENV, la transmisión del e-CF a la DGII queda en STUBBED (se construye y
# persiste el e-CF, como hasta ahora, pero NO se transmite). Para activar la transmisión real:
#   - DGII_ENV        → entorno DGII: test (TesteCF) | cert (CerteCF, set de certificación) | prod (eCF).
#   - DGII_BASE_URL   → (opcional) sobreescribe la URL base del entorno (confirmar con el kit DGII vigente).
#   - DGII_TIMEOUT_MS → (opcional) timeout de las llamadas a la DGII (default 20000).
# El CERTIFICADO digital del emisor (.p12) NO va aquí: es POR DESPACHO y se sube cifrado (Fase 3).
# Ver DGII_SETUP.md.
DGII_ENV=""
DGII_BASE_URL=""
DGII_TIMEOUT_MS="20000"

# ─── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── Consola de plataforma (super-admin / dueño) ─────────────────────
# Credenciales del super-admin que gestiona TODOS los despachos (suscripciones, prueba, plazas).
# Login en /api/platform/auth/login. En producción ponlas en `fly secrets`.
PLATFORM_ADMIN_EMAIL=""
PLATFORM_ADMIN_PASSWORD=""
# Secreto DEDICADO para firmar el JWT del super-admin (aíslalo de JWT_ACCESS_SECRET). En PRODUCCIÓN es
# OBLIGATORIO y debe ser DISTINTO de JWT_ACCESS_SECRET: el arranque falla si falta o si coincide (D-PLAT).
# Solo en dev/test cae a JWT_ACCESS_SECRET por comodidad. >=32 bytes.
PLATFORM_JWT_SECRET=""
# Vida del token de la consola de plataforma en segundos (default 3600 = 1 h). Cuanto menor, menor ventana
# de uso de un token robado (la consola no tiene revocación por jti todavía).
PLATFORM_TOKEN_TTL_SECONDS="3600"

# ─── IA (asistente / resúmenes / redacción / búsqueda semántica) ─────
# "Enchufar el agente" = definir ANTHROPIC_API_KEY. Sin clave, toda la IA queda DESHABILITADA (la app
# funciona igual; la UI muestra las features apagadas). El modelo es una sola variable.
#   - ANTHROPIC_API_KEY       → clave de la API de Anthropic (Claude). Vacío = IA off.
#   - AI_MODEL                → modelo a usar (default claude-opus-4-8). p. ej. claude-sonnet-4-6.
#   - AI_MAX_OUTPUT_TOKENS    → tope de tokens de salida por respuesta (default 4096; acotado a 8192).
#   - AI_DAILY_CALL_LIMIT     → cuota de llamadas a IA por despacho y día (default 200; control de coste).
#   - AI_DAILY_TOKEN_LIMIT    → tope de COSTE real: tokens (in+out) por despacho y día (default 2.000.000).
#                               Evita el denial-of-wallet por adjuntos grandes (un PDF de 8 MB ≠ un `ask`).
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"
AI_MAX_OUTPUT_TOKENS="4096"
AI_DAILY_CALL_LIMIT="200"
AI_DAILY_TOKEN_LIMIT="2000000"
# Búsqueda semántica (RAG). Embeddings vía Voyage (Anthropic no ofrece embeddings propios). Sin clave,
# la búsqueda semántica queda deshabilitada y se usa la búsqueda por texto existente.
#   - VOYAGE_API_KEY          → clave de Voyage AI. Vacío = búsqueda semántica off.
#   - AI_EMBEDDINGS_MODEL     → modelo de embeddings (default voyage-3).
#   - AI_EMBEDDINGS_DIMENSIONS→ dimensión del vector (default 1024; debe cuadrar con la migración).
VOYAGE_API_KEY=""
AI_EMBEDDINGS_MODEL="voyage-3"
AI_EMBEDDINGS_DIMENSIONS="1024"
